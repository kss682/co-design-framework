{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "colorSets": [
    "colset dot = {'dot'} timed;",
    "colset MESSAGE = {'M1', 'M2'} timed;"
  ],

  "places": [
    { "name": "ES1", "colorSet": "MESSAGE"},
    { "name": "NN", "colorSet": "MESSAGE"},
    { "name": "M1_Generator", "colorSet": "dot"}
  ],

  "transitions": [
    {
      "name": "release_m1",
      "variables": ["timer"],
      "guard": "timer >= 40",
      "inArcs": [
        { "place": "M1_Generator", "expression": "[timer]" }
      ],
      "outArcs": [
        { "place": "M1_Generator", "expression": "[timer]" },
        { "place": "ES1", "expression": "message" }
      ]
    }
  ],

  "initialMarking": {
    "ES1":         { "tokens": [ [] ] },
    "NN":         { "tokens": [ [] ] },
    "M1_Generator":         { "tokens": [ ["dot"] ] }
  },

  "evaluationContext": null
}